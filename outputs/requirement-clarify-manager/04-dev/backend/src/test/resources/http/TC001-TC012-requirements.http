###

# ─────────────────────────────────────────────────────────────
# TC-012 | 파일입력-보안 | XSS 방어 검증
# 기대: 201 Created, <script> 태그가 Sanitize 처리되어 저장
# ─────────────────────────────────────────────────────────────
### TC-012
POST {{baseUrl}}/api/v1/requirements
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="data"

{"projectName":"SecurityTestProject","requirementNo":"REQ-012","version":"1.0.0","title":"XSS 방어 검증","description":"<script>alert('XSS 공격 테스트')</script><img src=x onerror=alert(1)>정상 텍스트 포함"}
--boundary--

